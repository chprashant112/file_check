    # ─────────────────────────────────────────────────────────
    def _make_tree(self, parent, height=5):
        wrap_outer = Frame(parent, bg=COLORS["border"])
        wrap_outer.pack(fill=BOTH, expand=True)
        wrap = Frame(wrap_outer, bg=COLORS["panel"])
        wrap.pack(fill=BOTH, expand=True, padx=1, pady=1)

        tree = ttk.Treeview(wrap, show="headings", height=height,
                             style="Modern.Treeview")
        vsb = ttk.Scrollbar(wrap, orient="vertical",   command=tree.yview)
        hsb = ttk.Scrollbar(wrap, orient="horizontal", command=tree.xview)
        tree.configure(yscrollcommand=vsb.set, xscrollcommand=hsb.set)
        tree.grid(row=0, column=0, sticky=N + S + E + W)
        vsb.grid(row=0, column=1, sticky=N + S)
        hsb.grid(row=1, column=0, sticky=E + W)
        wrap.rowconfigure(0, weight=1)
        wrap.columnconfigure(0, weight=1)
        return tree

    # ─────────────────────────────────────────────────────────
    def log(self, msg, level="info"):
        icons = {"info": "·", "ok": "✔", "warn": "⚠", "err": "✖", "head": "═"}
        colors = {"ok": COLORS["success"], "warn": COLORS["warning"],
                  "err": COLORS["danger"], "head": COLORS["accent"]}

        icon = icons.get(level, "·")
        ts   = datetime.now().strftime("%H:%M:%S")
        line = f"[{ts}]  {icon}  {msg}\n"

        self.console_log.insert(END, line)
        self.console_log.see(END)

    def clear_console(self):
        self.console_log.delete("1.0", END)
        self.log("Console cleared.", "info")

    def _set_status(self, text, kind="neutral"):
        colors = {
            "neutral": (COLORS["panel_alt"], COLORS["text_dim"]),
            "ok":      (COLORS["tag_green"], COLORS["success"]),
            "warn":    ("#3d2e00",            COLORS["warning"]),
            "err":     (COLORS["tag_red"],    COLORS["danger"]),
            "run":     (COLORS["tag_blue"],   COLORS["accent"]),
        }
        bg, fg = colors.get(kind, colors["neutral"])
        self.status_var.set(text)
        self.status_pill.configure(bg=bg, fg=fg)

    # ─────────────────────────────────────────────────────────
    def handle_file_loading(self):
        files = filedialog.askopenfilenames(
            title="Select CSV Files",
            filetypes=[("CSV Files", "*.csv"), ("All Files", "*.*")]
        )
        if not files:
            return

        self.loaded_data.clear()
        self.file_stats.clear()

        self.log("", "head")
        self.log("Loading files…", "info")

        for f in files:
            name = os.path.basename(f)
            try:
                df = smart_read_csv(f)
                self.loaded_data[name] = df
                self.file_stats[name]  = (df.shape[0], df.shape[1])
                self.log(f"Loaded  {name}  →  {df.shape[0]} rows × {df.shape[1]} cols", "ok")
                self.log(f"   Columns: {', '.join(map(str, df.columns[:10]))}"
                         + (" …" if len(df.columns) > 10 else ""))
            except Exception as e:
                self.log(f"Failed to load  {name}:  {e}", "err")

        names = list(self.loaded_data.keys())
        self.base_file_combo["values"]    = names
        self.upgrade_file_combo["values"] = names

        if len(names) >= 1:
            self.base_file_combo.current(0)
        if len(names) >= 2:
            self.upgrade_file_combo.current(1)
        elif len(names) == 1:
            self.upgrade_file_combo.current(0)

        self.sync_interface()
        self._set_status(f"{len(names)} file(s) loaded", "ok")

    def sync_interface(self):
        base_name = self.base_file_var.get()
        up_name   = self.upgrade_file_var.get()

        self._populate_preview(base_name, self.base_tree)
        self._populate_preview(up_name,   self.upgrade_tree)

        def _stat(name, lbl):
            if name in self.file_stats:
                r, c = self.file_stats[name]
                lbl.configure(text=f"({r} rows, {c} cols)")
            else:
                lbl.configure(text="")

        _stat(base_name, self.base_stat_lbl)
        _stat(up_name,   self.upg_stat_lbl)

        if base_name in self.loaded_data:
            cols_b = [str(c) for c in self.loaded_data[base_name].columns]
            self.base_col_picker["values"] = cols_b
            if cols_b: self.base_col_picker.current(0)

        if up_name in self.loaded_data:
            cols_u = [str(c) for c in self.loaded_data[up_name].columns]
            self.upgrade_col_picker["values"] = cols_u
            if cols_u: self.upgrade_col_picker.current(0)

    def _populate_preview(self, name, tree):
        for item in tree.get_children():
            tree.delete(item)
        tree["columns"] = ()
        if name not in self.loaded_data:
            return
        df   = self.loaded_data[name].head(5)
        cols = [str(c) for c in df.columns]
        tree["columns"] = cols
        for c in cols:
            tree.heading(c, text=c)
            tree.column(c, width=120, anchor=W, stretch=False)
        for _, row in df.iterrows():
            tree.insert("", END, values=[str(v) for v in row.tolist()])

    # ─────────────────────────────────────────────────────────
    def add_mapping_row(self):
        b_col = self.base_col_var.get()
        u_col = self.upgrade_col_var.get()
        if not b_col or not u_col:
            self.log("Select both columns before adding a pair.", "warn")
            return
        # prevent duplicates
        existing = [(self.mapping_tree.item(i, "values")[1],
                     self.mapping_tree.item(i, "values")[2])
                    for i in self.mapping_tree.get_children()]
        if (b_col, u_col) in existing:
            self.log(f"Pair  {b_col} → {u_col}  already exists.", "warn")
            return
        idx = len(self.mapping_tree.get_children()) + 1
        self.mapping_tree.insert("", END, values=(idx, b_col, u_col))
        self.log(f"Mapping #{idx} added:  {b_col}  →  {u_col}", "ok")

    def remove_mapping_row(self):
        sel = self.mapping_tree.selection()
        if not sel:
            self.log("No mapping selected to remove.", "warn")
            return
        for s in sel:
            self.mapping_tree.delete(s)
        self._renumber_mappings()
        self.log(f"Removed {len(sel)} mapping(s).")

    def clear_mappings(self):
        for i in self.mapping_tree.get_children():
            self.mapping_tree.delete(i)
        self.log("All mappings cleared.")

    def _renumber_mappings(self):
        for idx, iid in enumerate(self.mapping_tree.get_children(), 1):
            vals = list(self.mapping_tree.item(iid, "values"))
            vals[0] = idx
            self.mapping_tree.item(iid, values=vals)

    # ─────────────────────────────────────────────────────────
    def run_audit_process(self):
        b_name = self.base_file_var.get()
        u_name = self.upgrade_file_var.get()

        if not b_name or not u_name:
            self.log("Select both Base and Upgraded files.", "err")
            self._set_status("Missing file selection", "err")
            return

        mappings = []
        for iid in self.mapping_tree.get_children():
            vals = self.mapping_tree.item(iid, "values")
            mappings.append((vals[1], vals[2]))          # (base_col, upgrade_col)

        if not mappings:
            self.log("No column mappings defined.", "err")
            self._set_status("No mappings defined", "warn")
            return

        self._set_status("Running…", "run")
        self.run_btn.configure(state="disabled", text="⏳  Running…")
        self.root.update_idletasks()

        try:
            self._do_audit(b_name, u_name, mappings)
        finally:
            self.run_btn.configure(state="normal", text="▶  RUN COMPARISON")

    # ─────────────────────────────────────────────────────────
    def _do_audit(self, b_name, u_name, mappings):
        self._run_count += 1
        self.log("", "head")
        self.log(f"Run #{self._run_count}  ·  {b_name}  vs  {u_name}", "head")

        try:
            df_b = self.loaded_data[b_name].copy().dropna(how="all")
            df_u = self.loaded_data[u_name].copy().dropna(how="all")

            # Primary key = first column of each file
            id_col_b = df_b.columns[0]
            id_col_u = df_u.columns[0]
            self.log(f"Primary key  ·  Base: '{id_col_b}'   Upgraded: '{id_col_u}'")

            df_b[id_col_b] = df_b[id_col_b].astype(str).str.strip()
            df_u[id_col_u] = df_u[id_col_u].astype(str).str.strip()

            keys_b = set(df_b[id_col_b])
            keys_u = set(df_u[id_col_u])

            missing_list  = sorted(keys_b - keys_u)
            new_items_list = sorted(keys_u - keys_b)
            common_ids    = keys_b & keys_u

            missing   = pd.DataFrame({"Parameter (Missing in Upgraded)": missing_list})
            new_items = pd.DataFrame({"Parameter (New in Upgraded)":    new_items_list})

            self.log(f"Common IDs: {len(common_ids)}   |   "
                     f"Only in Base: {len(missing_list)}   |   "
                     f"Only in Upgraded: {len(new_items_list)}")

            df_b_idx = (df_b[df_b[id_col_b].isin(common_ids)]
                        .drop_duplicates(id_col_b).set_index(id_col_b))
            df_u_idx = (df_u[df_u[id_col_u].isin(common_ids)]
                        .drop_duplicates(id_col_u).set_index(id_col_u))

            # Options
            do_strip  = bool(self.strip_spaces_var.get())
            case_sens = bool(self.case_sensitive_var.get())

            def _norm(v):
                s = str(v).strip() if do_strip else str(v)
                return s if case_sens else s.lower()

            # ── NEW comparison logic ───────────────────────────────────────
            #
            # For each common ID (parameter / row), gather the value from
            # every mapped column pair.  If ANY pair differs, include that
            # parameter in the report row.
            #
            # Output columns:
            #   Parameter  |  <B_col> (Base)  |  <U_col> (Upgraded)  | … per pair
            #
            # One Excel row = one parameter where at least one pair differs.
            # ──────────────────────────────────────────────────────────────

            # Build column headers for the variance sheet
            var_headers = ["Parameter"]
            for b_col, u_col in mappings:
                var_headers.append(f"{b_col} (Base)")
                var_headers.append(f"{u_col} (Upgraded)")

            variance_rows = []
            pairs_diff_counts = {f"{b}→{u}": 0 for b, u in mappings}

            for uid in sorted(common_ids):
                row_data   = {"Parameter": uid}
                has_diff   = False

                for b_col, u_col in mappings:
                    try:
                        v_b = df_b_idx.loc[uid, b_col]
                    except KeyError:
                        v_b = "N/A"
                    try:
                        v_u = df_u_idx.loc[uid, u_col]
                    except KeyError:
                        v_u = "N/A"

                    if _norm(v_b) != _norm(v_u):
                        has_diff = True
                        pairs_diff_counts[f"{b_col}→{u_col}"] += 1

                    row_data[f"{b_col} (Base)"]     = v_b
                    row_data[f"{u_col} (Upgraded)"] = v_u

                if has_diff:
                    variance_rows.append(row_data)

            variances_df = pd.DataFrame(variance_rows, columns=var_headers) \
                           if variance_rows else pd.DataFrame(columns=var_headers)

            # Summary
            summary_rows = [
                {"Metric": "Total common parameters", "Value": len(common_ids)},
                {"Metric": "Parameters with differences", "Value": len(variance_rows)},
                {"Metric": "Parameters removed in Upgraded", "Value": len(missing_list)},
                {"Metric": "Parameters new in Upgraded",     "Value": len(new_items_list)},
                {"Metric": "─── Differences per mapped pair ───", "Value": ""},
            ]
            for pair_key, cnt in pairs_diff_counts.items():
                summary_rows.append({"Metric": f"  {pair_key}", "Value": cnt})
            summary_df = pd.DataFrame(summary_rows)

            # Write Excel
            ts = datetime.now().strftime("%Y%m%d_%H%M%S")
            output_name = f"Audit_Report_{ts}.xlsx"

            with pd.ExcelWriter(output_name, engine="openpyxl") as writer:
                variances_df.to_excel(writer, sheet_name="Variances",     index=False)
                missing.to_excel(     writer, sheet_name="Removed_Items", index=False)
                new_items.to_excel(   writer, sheet_name="New_Items",     index=False)
                summary_df.to_excel(  writer, sheet_name="Summary",       index=False)

            # Apply rich styling
            style_excel_report(output_name, variances_df, missing, new_items, mappings)

            self.log(f"Report saved  →  {output_name}", "ok")
            self.log(f"  Parameters with differences : {len(variance_rows)}")
            self.log(f"  Removed                     : {len(missing_list)}")
            self.log(f"  New                         : {len(new_items_list)}")
            for pair_key, cnt in pairs_diff_counts.items():
                self.log(f"  Diffs in  {pair_key}  :  {cnt}")

            self._set_status(
                f"Done · {len(variance_rows)} diff(s) · {len(missing_list)} removed · {len(new_items_list)} new",
                "ok"
            )

            if self.open_after_var.get():
                try:
                    if os.name == "nt":
                        os.startfile(output_name)
                    elif sys.platform == "darwin":
                        os.system(f'open "{output_name}"')
                    else:
                        os.system(f'xdg-open "{output_name}"')
                except Exception as e:
                    self.log(f"(Could not auto-open file: {e})", "warn")

        except Exception as e:
            import traceback
            self.log(f"FATAL:  {e}", "err")
            self.log(traceback.format_exc(), "err")
            self._set_status("Error — see console", "err")


