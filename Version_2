#  EXCEL STYLER
# =========================================================
def style_excel_report(output_path, variances_df, missing_df, new_items_df, mappings):
    """Apply rich formatting to the Excel report."""
    wb = load_workbook(output_path)

    # ── colour palette ──────────────────────────────────────
    H_FILL   = PatternFill("solid", fgColor="1A2744")   # header: dark blue
    VAR_FILL = PatternFill("solid", fgColor="1C1C2E")   # variance rows
    ALT_FILL = PatternFill("solid", fgColor="111122")   # alternate rows
    B_FILL   = PatternFill("solid", fgColor="0D2233")   # base value cells
    U_FILL   = PatternFill("solid", fgColor="0D3322")   # upgraded value cells
    P_FILL   = PatternFill("solid", fgColor="1E1E1E")   # parameter cell
    DIFF_FILL= PatternFill("solid", fgColor="3D1515")   # cells with actual diff
    REM_FILL = PatternFill("solid", fgColor="2D1010")
    NEW_FILL = PatternFill("solid", fgColor="0D2D18")
    SUMM_FILL= PatternFill("solid", fgColor="0A0F20")

    H_FONT    = Font(name="Calibri", bold=True, color="A8BFFF", size=10)
    PARAM_FONT= Font(name="Calibri", bold=True, color="E8E8E8", size=10)
    BASE_FONT = Font(name="Calibri", color="7EC8E3", size=10)
    UPG_FONT  = Font(name="Calibri", color="7EE8C0", size=10)
    DIFF_FONT = Font(name="Calibri", bold=True, color="FF8080", size=10)
    NORM_FONT = Font(name="Calibri", color="CCCCCC", size=10)

    thin  = Side(style="thin",   color="2A3550")
    thick = Side(style="medium", color="3D5080")
    outer_border = Border(left=thick, right=thick, top=thick, bottom=thick)
    inner_border = Border(left=thin,  right=thin,  top=thin,  bottom=thin)
    center = Alignment(horizontal="center", vertical="center", wrap_text=False)
    left_a = Alignment(horizontal="left",   vertical="center", wrap_text=False)

    def _apply_sheet(ws, df, header_labels, col_styles):
        """Generic sheet formatter."""
        ws.sheet_view.showGridLines = False
        ws.sheet_properties.tabColor = "1A2744"

        # header row
        for col_idx, label in enumerate(header_labels, 1):
            cell = ws.cell(row=1, column=col_idx)
            cell.value = label
            cell.fill = H_FILL
            cell.font = H_FONT
            cell.alignment = center
            cell.border = inner_border

        # data rows
        for row_idx, row_data in enumerate(df.itertuples(index=False), 2):
            row_fill = VAR_FILL if row_idx % 2 == 0 else ALT_FILL
            for col_idx, (val, style) in enumerate(zip(row_data, col_styles), 1):
                cell = ws.cell(row=row_idx, column=col_idx, value=str(val) if pd.notna(val) else "")
                cell.alignment = left_a
                cell.border = inner_border
                if style == "param":
                    cell.fill = P_FILL
                    cell.font = PARAM_FONT
                elif style == "base":
                    cell.fill = B_FILL
                    cell.font = BASE_FONT
                elif style == "upgraded":
                    cell.fill = U_FILL
                    cell.font = UPG_FONT
                elif style == "diff":
                    cell.fill = DIFF_FILL
                    cell.font = DIFF_FONT
                elif style == "removed":
                    cell.fill = REM_FILL
                    cell.font = Font(name="Calibri", color="FF9999", size=10)
                elif style == "added":
                    cell.fill = NEW_FILL
                    cell.font = Font(name="Calibri", color="99FFbb", size=10)
                else:
                    cell.fill = row_fill
                    cell.font = NORM_FONT

        # column widths
        for col_idx, col in enumerate(ws.iter_cols(min_row=1, max_row=ws.max_row), 1):
            max_len = max((len(str(c.value or "")) for c in col), default=10)
            ws.column_dimensions[get_column_letter(col_idx)].width = min(max_len + 4, 45)

        # freeze header
        ws.freeze_panes = "A2"
        # row height
        ws.row_dimensions[1].height = 22
        for r in range(2, ws.max_row + 1):
            ws.row_dimensions[r].height = 20

    # ── VARIANCES sheet ─────────────────────────────────────
    ws_var = wb["Variances"]
    if not variances_df.empty:
        headers = list(variances_df.columns)
        # Build style list: first col = param, then alternating base/upgraded per mapping
        col_styles = ["param"]
        for b_col, u_col in mappings:
            col_styles.append("base")
            col_styles.append("upgraded")
        # diff detection: mark upgraded cells where value differs from base
        # We'll do it row by row below

        ws_var.sheet_view.showGridLines = False
        ws_var.sheet_properties.tabColor = "1A2744"

        # header
        for ci, h in enumerate(headers, 1):
            cell = ws_var.cell(row=1, column=ci)
            cell.value = h
            cell.fill = H_FILL
            cell.font = H_FONT
            cell.alignment = center
            cell.border = inner_border

        # data
        for ri, (_, row) in enumerate(variances_df.iterrows(), 2):
            fill = VAR_FILL if ri % 2 == 0 else ALT_FILL
            for ci, col_name in enumerate(headers, 1):
                val = row[col_name]
                cell = ws_var.cell(row=ri, column=ci, value=str(val) if pd.notna(val) else "—")
                cell.border = inner_border
                cell.alignment = left_a

                if ci == 1:                         # Parameter column
                    cell.fill = P_FILL
                    cell.font = PARAM_FONT
                else:
                    # figure out if this is a base or upgraded col, and if there's a diff
                    col_idx_0 = ci - 2              # 0-based after param col
                    pair_idx   = col_idx_0 // 2
                    is_upgraded = col_idx_0 % 2 == 1

                    if 0 <= pair_idx < len(mappings):
                        b_col_h = f"{mappings[pair_idx][0]} (Base)"
                        u_col_h = f"{mappings[pair_idx][1]} (Upgraded)"
                        base_val = str(row.get(b_col_h, "")).strip()
                        upgr_val = str(row.get(u_col_h, "")).strip()
                        has_diff = base_val != upgr_val

                        if not is_upgraded:
                            cell.fill = B_FILL
                            cell.font = DIFF_FONT if has_diff else BASE_FONT
                        else:
                            cell.fill = DIFF_FILL if has_diff else U_FILL
                            cell.font = DIFF_FONT if has_diff else UPG_FONT
                    else:
                        cell.fill = fill
                        cell.font = NORM_FONT

        # col widths & freeze
        for col in ws_var.iter_cols(min_row=1, max_row=ws_var.max_row):
            max_len = max((len(str(c.value or "")) for c in col), default=10)
            ws_var.column_dimensions[get_column_letter(col[0].column)].width = min(max_len + 4, 42)
        ws_var.freeze_panes = "A2"
        ws_var.row_dimensions[1].height = 22
        for r in range(2, ws_var.max_row + 1):
            ws_var.row_dimensions[r].height = 20

    # ── REMOVED sheet ───────────────────────────────────────
    if "Removed_Items" in wb.sheetnames:
        ws_rem = wb["Removed_Items"]
        ws_rem.sheet_view.showGridLines = False
        if not missing_df.empty:
            _apply_sheet(ws_rem, missing_df,
                         list(missing_df.columns),
                         ["removed"] * len(missing_df.columns))

    # ── NEW ITEMS sheet ─────────────────────────────────────
    if "New_Items" in wb.sheetnames:
        ws_new = wb["New_Items"]
        ws_new.sheet_view.showGridLines = False
        if not new_items_df.empty:
            _apply_sheet(ws_new, new_items_df,
                         list(new_items_df.columns),
                         ["added"] * len(new_items_df.columns))

    # ── SUMMARY sheet ───────────────────────────────────────
    if "Summary" in wb.sheetnames:
        ws_sum = wb["Summary"]
        ws_sum.sheet_view.showGridLines = False
        ws_sum.sheet_properties.tabColor = "223344"
        for row in ws_sum.iter_rows():
            for cell in row:
                cell.fill = SUMM_FILL
                if cell.row == 1:
                    cell.font = Font(name="Calibri", bold=True, color="A8BFFF", size=11)
                else:
                    cell.font = Font(name="Calibri", color="CCCCCC", size=10)
                cell.alignment = left_a

    wb.save(output_path)


