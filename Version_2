    def _card(self, parent, title=None, accent_line=True, **pack_kw):
        """Bordered card with optional top accent line."""
        outer = Frame(parent, bg=COLORS["border"])
        outer.pack(**pack_kw)
        if accent_line:
            accent = Frame(outer, bg=COLORS["accent"], height=2)
            accent.pack(fill=X)
        inner = Frame(outer, bg=COLORS["panel"], padx=16, pady=12)
        inner.pack(fill=BOTH, expand=True, padx=1, pady=(0, 1))
        if title:
            self._section_label(inner, title).pack(fill=X, pady=(0, 8))
        return inner

    def _section_label(self, parent, text):
        row = Frame(parent, bg=COLORS["panel"])
        Label(row, text=text, bg=COLORS["panel"], fg=COLORS["accent"],
              font=FONTS["h2"]).pack(side=LEFT)
        Frame(row, bg=COLORS["border_light"], height=1).pack(
            side=LEFT, fill=X, expand=True, padx=(10, 0), pady=(2, 0))
        return row

