# =========================================================
#  SMART CSV READER
# =========================================================
def smart_read_csv(path):
    """Strips /*===...===*/ junk and reads clean CSV."""
    with open(path, "r", encoding="utf-8-sig", errors="replace", newline="") as f:
        raw_lines = f.readlines()

    cleaned = []
    for line in raw_lines:
        stripped = line.strip()
        if not stripped:
            continue
        if re.fullmatch(r"[/*=\-#\s]+", stripped):
            continue
        if stripped.startswith("/*") and "," not in stripped and ";" not in stripped:
            continue
        if stripped.endswith("*/") and "," not in stripped and ";" not in stripped:
            continue
        line2 = re.sub(r"^/\*+\s*", "", line)
        line2 = re.sub(r"\s*\*+/\s*$", "", line2)
        line2 = re.sub(r"^[=\-*#/\s]+", "", line2)
        line2 = re.sub(r"[=\-*#/\s]+$", "", line2) + "\n"
        if line2.strip():
            cleaned.append(line2)

    if not cleaned:
        return pd.read_csv(path)

    text = "".join(cleaned)
    try:
        sep = csv.Sniffer().sniff(text[:2048], delimiters=",;\t|").delimiter
    except Exception:
        sep = ","

    df = pd.read_csv(StringIO(text), sep=sep, engine="python")
    df.columns = [
        re.sub(r"^[=\-*#/\s\"']+|[=\-*#/\s\"']+$", "", str(c)).strip()
        for c in df.columns
    ]
    df = df.dropna(axis=1, how="all")
    df = df.loc[:, [c for c in df.columns if c and not str(c).lower().startswith("unnamed")]]
    return df


